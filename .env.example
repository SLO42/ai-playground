# ─── Required API Keys ────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# Anthropic API key for Claude model access
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenClaw gateway authentication token (generate with: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# ─── Ollama (Local Model — Primary) ───────────────────────
# Ollama runs locally, no real API key needed
OLLAMA_API_KEY=ollama-local
# Ollama host (default: http://127.0.0.1:11434)
OLLAMA_HOST=http://127.0.0.1:11434

# ─── Optional Configuration ───────────────────────────────
# OpenClaw gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Ruflo MCP server port (default: 3000)
RUFLO_MCP_PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─── HEB Grocery MCP ─────────────────────────────────────
# Default H-E-B store ID (find via store_search tool)
HEB_DEFAULT_STORE=
# Optional: Redis URL for caching (default: in-memory)
# REDIS_URL=redis://localhost:6379

# ─── Twitch Channel ──────────────────────────────────────
# Bot account OAuth token (get from https://twitchtokengen.com)
TWITCH_OAUTH_TOKEN=
# Twitch app client ID (register at https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=
# Bot username on Twitch
TWITCH_BOT_USERNAME=

# ─── Other Channel API Keys (add as needed) ──────────────
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SIGNAL_PHONE_NUMBER=
